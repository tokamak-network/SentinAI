# OP Stack local launcher configuration
# Copy to .env and fill required values.

# ==========================================
# REQUIRED: L1 configuration (Sepolia)
# ==========================================
# Option A: Public endpoint (no API key)
L1_RPC_URL="https://ethereum-sepolia-rpc.publicnode.com"
L1_BEACON_URL="https://ethereum-sepolia-beacon-api.publicnode.com"

# Option B: Private endpoint (Infura/Alchemy)
# L1_RPC_URL="https://sepolia.infura.io/v3/YOUR_API_KEY"
# L1_BEACON_URL="https://ethereum-sepolia-beacon-api.publicnode.com"

# ==========================================
# REQUIRED: deployment private key
# ==========================================
# Remove 0x prefix.
# Never commit real private keys.
PRIVATE_KEY="YOUR_PRIVATE_KEY_WITHOUT_0X_PREFIX"

# ==========================================
# REQUIRED: L2 chain configuration
# ==========================================
L2_CHAIN_ID="16584"

# ==========================================
# OPTIONAL: local networking
# ==========================================
P2P_ADVERTISE_IP="127.0.0.1"

# ==========================================
# OPTIONAL: upstream fetch controls
# ==========================================
# Pin to a specific tag or commit SHA. Do not use 'main' or 'latest'.
OPSTACK_UPSTREAM_REF="f4da86bd742a4a88f41ccbeed54b62a98983d1dd"
# Pin op-deployer release tag. Do not use 'latest'.
OPSTACK_OP_DEPLOYER_REF="op-deployer/v0.6.0-rc.3"
# Pin optimism ref used for op-program prestate generation.
OPSTACK_OPTIMISM_REF="op-program/v1.9.0"
# OPSTACK_UPSTREAM_REPO_URL="https://github.com/ethereum-optimism/docs.git"
# OPSTACK_DOCKER_PROJECT="create-l2-rollup-example"
# OPSTACK_PATCH_DIR="/absolute/path/to/SentinAI/examples/opstack/patches"
