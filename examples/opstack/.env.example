# OP Stack L2 Rollup Environment Configuration
# Copy this file to .env and fill required values.

# ==========================================
# REQUIRED: L1 configuration (Sepolia)
# ==========================================
# Public endpoint example (no API key)
L1_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/zPJeUK2LKGg4LjvHPGXYl1Ef4FJ_u7Gn"
L1_BEACON_URL="https://ethereum-sepolia-beacon-api.publicnode.com"

# Private endpoint example (Alchemy/Infura)
# L1_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY"
# L1_BEACON_URL="https://ethereum-sepolia-beacon-api.publicnode.com"

# ==========================================
# REQUIRED: deployment private key
# ==========================================
# Do not include 0x prefix.
# Never commit real private keys.
PRIVATE_KEY="679d88a9fb565707c0aff9434f9c141fee0b197455c12a52868b5d94bac694f9"

# ==========================================
# REQUIRED: L2 configuration
# ==========================================
L2_CHAIN_ID="16584"

# ==========================================
# OPTIONAL: local networking
# ==========================================
P2P_ADVERTISE_IP="127.0.0.1"

# ==========================================
# OPTIONAL: local L1 development
# ==========================================
# L1_RPC_URL="http://host.docker.internal:8545"
# L1_BEACON_URL="http://host.docker.internal:5052"
