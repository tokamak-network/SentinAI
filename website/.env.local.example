# SentinAI Website Admin Marketplace Environment Variables
# Copy this file to .env.local and fill in the required values

# ===== SIWE Admin Authentication =====
# The authorized wallet address for marketplace admin access
# Must be a valid Ethereum address in checksum format
# Example: 0x742d35Cc6634C0532925a3b844Bc92d426D00Eff
NEXT_PUBLIC_MARKETPLACE_ADMIN_KEY=

# Secret key used to generate HMAC-based session tokens
# Should be a random string at least 32 characters long
# If not set, falls back to insecure default (NOT for production)
# Generate with: openssl rand -base64 32
MARKETPLACE_SESSION_KEY=

# ===== Optional: Session Configuration =====
# Session token TTL in milliseconds (default: 8 hours = 28,800,000 ms)
# Adjust if you need different session timeout
# ADMIN_SESSION_TTL_MS=28800000

# ===== Next.js Configuration =====
# Set to 'production' for Vercel deployments
NODE_ENV=development

# ===== Development Only =====
# These are optional for local development
# NEXT_PUBLIC_API_URL=http://localhost:3003

# ===== Security Notes =====
# 1. Admin Address:
#    - Must match the wallet that will sign in
#    - Use Etherscan to verify checksummed address
#    - Example: https://etherscan.io/address/0x742d35Cc6634C0532925a3b844Bc92d426D00Eff
#
# 2. Session Key:
#    - Keep this secret - it's used to sign session tokens
#    - Never commit .env.local to version control
#    - Rotate periodically in production
#    - Users will be logged out if you change this
#
# 3. MetaMask:
#    - Users need MetaMask or compatible Ethereum wallet
#    - Sign-In with Ethereum (SIWE) standard
#    - Nonce expires after 5 minutes
#    - Session tokens valid for 8 hours

# ===== Deployment Checklist =====
# Before deploying to Vercel:
# ✓ Set NEXT_PUBLIC_MARKETPLACE_ADMIN_KEY to production admin address
# ✓ Generate secure MARKETPLACE_SESSION_KEY
# ✓ Use Vercel's secret management for sensitive values
# ✓ Test login flow in staging before production
# ✓ Ensure MetaMask wallet matches admin address
